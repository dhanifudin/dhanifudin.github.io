---
import { getCollection } from 'astro:content';
import EditorLayout from '../layouts/EditorLayout.astro';
import Dashboard from '../components/nvim/Dashboard.vue';

const allPosts    = await getCollection('blog', ({ data }) => !data.draft).catch(() => []);
const allProjects = await getCollection('projects').catch(() => []);
const buildDate   = new Date().toLocaleDateString('en', { year: 'numeric', month: 'short', day: 'numeric' });
---

<EditorLayout title="Dashboard" description="Dian Hanifudin Subhi — Software Engineer personal site">
  <Dashboard
    client:only="vue"
    buildDate={buildDate}
    postCount={allPosts.length}
    projectCount={allProjects.length}
  />
</EditorLayout>
