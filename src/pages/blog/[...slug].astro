---
import { getCollection, render } from 'astro:content';
import EditorLayout from '../../layouts/EditorLayout.astro';
import LineGutter from '../../components/nvim/LineGutter.astro';
import TableOfContents from '../../components/nvim/TableOfContents.astro';
import SeriesNavigation from '../../components/nvim/SeriesNavigation.astro';
import RelatedPosts from '../../components/nvim/RelatedPosts.astro';
import JsonLd from '../../components/JsonLd.astro';
import { slugify } from '../../utils/slugify';
import { getAdjacentPosts } from '../../utils/postNav';
import { getRelatedPosts } from '../../utils/relatedPosts';
import { formatReadingTime } from '../../utils/readingTime';
import { createBlogPostingJsonLd } from '../../utils/jsonld';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props:  { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const readingTime = formatReadingTime(post.body);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const { prev, next } = getAdjacentPosts(sortedPosts, post.id);
const relatedPosts = getRelatedPosts(
  sortedPosts,
  post.id,
  post.data.tags,
  post.data.series?.id,
);

const blogJsonLd = createBlogPostingJsonLd(post, post.id);
---

<EditorLayout title={post.data.title} description={post.data.description} ogType="article">
  <JsonLd data={blogJsonLd} />
  <div class="blog-grid">
    <!-- Post header -->
    <div class="blog-header">
      <div
        style="
          display: flex;
          align-items: center;
          gap: 12px;
          margin-bottom: 0.5rem;
          padding-bottom: 0.75rem;
          border-bottom: 1px solid var(--ctp-surface0);
          font-size: 12px;
          color: var(--ctp-overlay0);
        "
      >
        <span style="color: var(--ctp-blue);">✎</span>
        <span>blog/{post.id}.md</span>
        <span style="margin-left: auto; display: flex; gap: 12px;">
          <span>{new Date(post.data.date).toLocaleDateString('en', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
          <span>{readingTime}</span>
        </span>
      </div>

      <h1 style="color: var(--ctp-mauve); font-size: 1.6rem; font-weight: 600; margin-bottom: 0.5rem; margin-top: 1.5rem;">
        {post.data.title}
      </h1>

      {post.data.description && (
        <p style="color: var(--ctp-subtext0); font-size: 13px; margin-bottom: 1.5rem; border-left: 2px solid var(--ctp-blue); padding-left: 12px;">
          {post.data.description}
        </p>
      )}

      {post.data.tags.length > 0 && (
        <div style="display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 0.75rem;">
          {post.data.tags.map(tag => (
            <a
              href={`/tags/${slugify(tag)}`}
              style="padding: 2px 10px; background: var(--ctp-surface0); border-radius: 999px; font-size: 11px; color: var(--ctp-blue); text-decoration: none;"
              class="tag-badge"
            >
              #{tag}
            </a>
          ))}
        </div>
      )}

      {post.data.series && (
        <SeriesNavigation series={post.data.series} currentPostId={post.id} />
      )}
    </div>

    <!-- Table of contents: between header and content in DOM (mobile natural position) -->
    <div class="blog-toc">
      <TableOfContents headings={headings} />
    </div>

    <!-- Post body -->
    <div class="blog-body">
      <LineGutter>
        <article class="prose">
          <Content />

          <!-- Prev/Next navigation -->
          {(prev || next) && (
            <nav
              class="post-nav"
              style="
                margin-top: 3rem;
                padding-top: 1rem;
                border-top: 1px solid var(--ctp-surface0);
              "
            >
              {prev ? (
                <a href={`/blog/${prev.id}`} class="post-nav-link">
                  <span class="post-nav-arrow">← Previous</span>
                  <span class="post-nav-title">{prev.data.title}</span>
                </a>
              ) : (
                <span />
              )}
              {next ? (
                <a href={`/blog/${next.id}`} class="post-nav-link post-nav-next">
                  <span class="post-nav-arrow">Next →</span>
                  <span class="post-nav-title">{next.data.title}</span>
                </a>
              ) : (
                <span />
              )}
            </nav>
          )}

          <RelatedPosts relatedPosts={relatedPosts} />

          <!-- Footer nav -->
          <div
            style="
              margin-top: 1.5rem;
              padding-top: 1rem;
              border-top: 1px solid var(--ctp-surface0);
              display: flex;
              justify-content: space-between;
              font-size: 13px;
            "
          >
            <a href="/blog" style="color: var(--ctp-blue); text-decoration: none;">← back to blog</a>
            <a href="#" onclick="window.scrollTo(0,0);return false;" style="color: var(--ctp-overlay0); text-decoration: none;">↑ top</a>
          </div>
        </article>
      </LineGutter>
    </div>
  </div>
</EditorLayout>

<style>
  .blog-grid {
    display: grid;
    grid-template-columns: 1fr 240px;
    grid-template-rows: auto 1fr;
    gap: 0 2rem;
  }

  .blog-header { grid-column: 1; grid-row: 1; }
  .blog-body   { grid-column: 1; grid-row: 2; min-width: 0; }
  .blog-toc    {
    grid-column: 2;
    grid-row: 1 / 3;
    position: sticky;
    top: 1.25rem;
    align-self: start;
    max-height: calc(100vh - 80px);
    overflow-y: auto;
  }

  /* Hide the top margin of the first content heading so it aligns with TOC */
  .prose > :first-child {
    margin-top: 0;
  }

  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 10px 14px;
    border: 1px solid var(--ctp-surface0);
    border-radius: 6px;
    text-decoration: none;
    transition: border-color 0.1s, background 0.1s;
  }

  .post-nav-link:hover {
    border-color: var(--ctp-blue);
    background: var(--ctp-surface0);
  }

  .post-nav-next {
    text-align: right;
  }

  .post-nav-title {
    color: var(--ctp-text);
    font-size: 14px;
    font-weight: 500;
  }

  .post-nav-arrow {
    color: var(--ctp-overlay0);
    font-size: 12px;
  }

  @media (max-width: 768px) {
    .blog-grid {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .blog-toc {
      position: static;
      max-height: none;
      overflow-y: visible;
      margin-bottom: 1.25rem;
    }

    .post-nav {
      grid-template-columns: 1fr;
    }

    .post-nav-next {
      text-align: left;
    }
  }
</style>

<style is:global>
  .tag-badge:hover {
    background: var(--ctp-surface1) !important;
  }
</style>
