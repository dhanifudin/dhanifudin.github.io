---
import { getCollection, render } from 'astro:content';
import EditorLayout from '../../layouts/EditorLayout.astro';
import LineGutter from '../../components/nvim/LineGutter.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props:  { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const readingTime = Math.ceil(post.body?.split(/\s+/).length / 200);
---

<EditorLayout title={post.data.title} description={post.data.description}>
  <LineGutter>
    <article class="prose">
      <!-- File info header (buffer modeline style) -->
      <div
        style="
          display: flex;
          align-items: center;
          gap: 12px;
          margin-bottom: 1.5rem;
          padding-bottom: 0.75rem;
          border-bottom: 1px solid var(--ctp-surface0);
          font-size: 12px;
          color: var(--ctp-overlay0);
        "
      >
        <span style="color: var(--ctp-blue);">✎</span>
        <span>blog/{post.id}.md</span>
        <span style="margin-left: auto; display: flex; gap: 12px;">
          <span>{new Date(post.data.date).toLocaleDateString('en', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
          <span>~{readingTime} min read</span>
        </span>
      </div>

      <h1>{post.data.title}</h1>

      {post.data.description && (
        <p style="color: var(--ctp-subtext0); font-size: 13px; margin-bottom: 1.5rem; border-left: 2px solid var(--ctp-blue); padding-left: 12px;">
          {post.data.description}
        </p>
      )}

      {post.data.tags.length > 0 && (
        <div style="display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 1.5rem;">
          {post.data.tags.map(tag => (
            <span style="padding: 2px 10px; background: var(--ctp-surface0); border-radius: 999px; font-size: 11px; color: var(--ctp-blue);">
              #{tag}
            </span>
          ))}
        </div>
      )}

      <Content />

      <!-- Footer nav -->
      <div
        style="
          margin-top: 3rem;
          padding-top: 1rem;
          border-top: 1px solid var(--ctp-surface0);
          display: flex;
          justify-content: space-between;
          font-size: 13px;
        "
      >
        <a href="/blog" style="color: var(--ctp-blue); text-decoration: none;">← back to blog</a>
        <a href="#" onclick="window.scrollTo(0,0);return false;" style="color: var(--ctp-overlay0); text-decoration: none;">↑ top</a>
      </div>
    </article>
  </LineGutter>
</EditorLayout>
