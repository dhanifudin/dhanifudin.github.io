---
import { getCollection } from 'astro:content';
import EditorLayout from '../../layouts/EditorLayout.astro';
import LineGutter from '../../components/nvim/LineGutter.astro';
import { slugify } from '../../utils/slugify';
import { formatReadingTime } from '../../utils/readingTime';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const tagMap = new Map<string, string>();

  for (const post of allPosts) {
    for (const tag of post.data.tags) {
      const slug = slugify(tag);
      if (!tagMap.has(slug)) {
        tagMap.set(slug, tag);
      }
    }
  }

  return Array.from(tagMap.entries()).map(([slug, rawTag]) => ({
    params: { tag: slug },
    props: {
      rawTag,
      posts: allPosts
        .filter((p) => p.data.tags.includes(rawTag))
        .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()),
    },
  }));
}

const { rawTag, posts } = Astro.props;
const pageDescription = `${posts.length} post${posts.length !== 1 ? 's' : ''} tagged "${rawTag}"`;
---

<EditorLayout title={`#${rawTag}`} description={pageDescription}>
  <LineGutter>
    <div>
      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 0.5rem;">
        <a href="/tags" style="color: var(--ctp-blue); text-decoration: none; font-size: 13px;">← all tags</a>
      </div>
      <h1
        style="
          color: var(--ctp-mauve);
          font-size: 1.4rem;
          font-weight: 600;
          margin-bottom: 0.5rem;
          display: flex;
          align-items: center;
          gap: 8px;
        "
      >
        <span style="padding: 1px 10px; background: var(--ctp-surface0); border-radius: 999px; font-size: 13px; color: var(--ctp-blue);">
          #{rawTag}
        </span>
        <span style="color: var(--ctp-overlay0); font-size: 1rem; font-weight: 400;">
          — {posts.length} post{posts.length !== 1 ? 's' : ''}
        </span>
      </h1>

      {posts.length === 0 ? (
        <p style="color: var(--ctp-overlay0); font-size: 13px;">
          No posts with this tag.
        </p>
      ) : (
        <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem;">
          {posts.map(post => (
            <li>
              <a
                href={`/blog/${post.id}`}
                style="
                  display: block;
                  padding: 12px 16px;
                  border-radius: 6px;
                  border: 1px solid var(--ctp-surface0);
                  text-decoration: none;
                  transition: border-color 0.1s, background 0.1s;
                "
                class="post-card"
              >
                <div style="display: flex; justify-content: space-between; align-items: baseline; gap: 8px; flex-wrap: wrap;">
                  <span style="color: var(--ctp-text); font-size: 14px; font-weight: 500;">
                    ✎ {post.data.title}
                  </span>
                  <span style="display: flex; gap: 10px; align-items: center; color: var(--ctp-overlay0); font-size: 12px; flex-shrink: 0;">
                    <span>{new Date(post.data.date).toLocaleDateString('en', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
                    <span>{formatReadingTime(post.body)}</span>
                  </span>
                </div>
                {post.data.description && (
                  <p style="color: var(--ctp-subtext0); font-size: 12px; margin-top: 4px; margin-bottom: 0;">
                    {post.data.description}
                  </p>
                )}
                {post.data.tags.length > 0 && (
                  <div style="display: flex; gap: 4px; flex-wrap: wrap; margin-top: 8px;">
                    {post.data.tags.map(tag => (
                      <a
                        href={`/tags/${slugify(tag)}`}
                        style="padding: 1px 8px; background: var(--ctp-surface0); border-radius: 999px; font-size: 11px; color: var(--ctp-blue); text-decoration: none;"
                        class="tag-badge"
                      >
                        {tag}
                      </a>
                    ))}
                  </div>
                )}
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </LineGutter>
</EditorLayout>

<style is:global>
.post-card:hover {
  border-color: var(--ctp-blue) !important;
  background: var(--ctp-surface0) !important;
}
.tag-badge:hover {
  background: var(--ctp-surface1) !important;
}
</style>
