---
import { getCollection } from 'astro:content';
import EditorLayout from '../../layouts/EditorLayout.astro';
import LineGutter from '../../components/nvim/LineGutter.astro';
import { slugify } from '../../utils/slugify';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const tagCounts = new Map<string, number>();

for (const post of allPosts) {
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  }
}

const sortedTags = Array.from(tagCounts.entries()).sort((a, b) =>
  a[0].toLowerCase().localeCompare(b[0].toLowerCase())
);

const totalPosts = allPosts.length;
---

<EditorLayout title="Tags" description={`Browse ${tagCounts.size} tags across ${totalPosts} blog posts`}>
  <LineGutter>
    <div>
      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 0.5rem;">
        <a href="/blog" style="color: var(--ctp-blue); text-decoration: none; font-size: 13px;">← back to blog</a>
      </div>
      <h1
        style="
          color: var(--ctp-mauve);
          font-size: 1.4rem;
          font-weight: 600;
          margin-bottom: 1.5rem;
          display: flex;
          align-items: center;
          gap: 8px;
        "
      >
        <span>#</span>
        <span>tags</span>
        <span style="color: var(--ctp-overlay0); font-size: 1rem; font-weight: 400;">
          — {tagCounts.size} tag{tagCounts.size !== 1 ? 's' : ''} · {totalPosts} post{totalPosts !== 1 ? 's' : ''}
        </span>
      </h1>

      {sortedTags.length === 0 ? (
        <p style="color: var(--ctp-overlay0); font-size: 13px;">
          No tags yet.
        </p>
      ) : (
        <div style="display: flex; flex-wrap: wrap; gap: 10px;">
          {sortedTags.map(([tag, count]) => (
            <a
              href={`/tags/${slugify(tag)}`}
              style="
                display: inline-flex;
                align-items: center;
                gap: 6px;
                padding: 4px 14px;
                background: var(--ctp-surface0);
                border-radius: 999px;
                font-size: 13px;
                color: var(--ctp-blue);
                text-decoration: none;
                transition: background 0.1s, border-color 0.1s;
                border: 1px solid var(--ctp-surface0);
              "
              class="tag-pill"
            >
              <span>#{tag}</span>
              <span style="font-size: 11px; color: var(--ctp-overlay0);">{count}</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </LineGutter>
</EditorLayout>

<style is:global>
.tag-pill:hover {
  background: var(--ctp-surface1) !important;
  border-color: var(--ctp-blue) !important;
}
</style>
