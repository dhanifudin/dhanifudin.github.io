---
import { getCollection, render } from 'astro:content';
import EditorLayout from '../../layouts/EditorLayout.astro';
import LineGutter from '../../components/nvim/LineGutter.astro';
import JsonLd from '../../components/JsonLd.astro';
import { createSoftwareApplicationJsonLd } from '../../utils/jsonld';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props:  { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const projectJsonLd = createSoftwareApplicationJsonLd(project, project.id);
---

<EditorLayout title={project.data.title} description={project.data.description}>
  <JsonLd data={projectJsonLd} />
  <LineGutter>
    <article class="prose">
      <!-- File info header -->
      <div
        style="
          display: flex;
          align-items: center;
          gap: 12px;
          margin-bottom: 1.5rem;
          padding-bottom: 0.75rem;
          border-bottom: 1px solid var(--ctp-surface0);
          font-size: 12px;
          color: var(--ctp-overlay0);
        "
      >
        <span style="color: var(--ctp-blue);">◈</span>
        <span>projects/{project.id}.md</span>
        <div style="margin-left: auto; display: flex; gap: 8px;">
          {project.data.repo && (
            <a href={project.data.repo} target="_blank" rel="noopener"
               style="color: var(--ctp-blue); text-decoration: none; font-size: 12px;">↗ repo</a>
          )}
          {project.data.url && (
            <a href={project.data.url} target="_blank" rel="noopener"
               style="color: var(--ctp-green); text-decoration: none; font-size: 12px;">↗ live</a>
          )}
        </div>
      </div>

      <h1>{project.data.title}</h1>

      <p style="color: var(--ctp-subtext0); font-size: 13px; margin-bottom: 1rem; border-left: 2px solid var(--ctp-blue); padding-left: 12px;">
        {project.data.description}
      </p>

      {project.data.tags.length > 0 && (
        <div style="display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 1.5rem;">
          {project.data.tags.map(tag => (
            <span style="padding: 2px 10px; background: var(--ctp-surface0); border-radius: 999px; font-size: 11px; color: var(--ctp-teal);">
              {tag}
            </span>
          ))}
        </div>
      )}

      <Content />

      <div
        style="
          margin-top: 3rem;
          padding-top: 1rem;
          border-top: 1px solid var(--ctp-surface0);
          display: flex;
          justify-content: space-between;
          font-size: 13px;
        "
      >
        <a href="/projects" style="color: var(--ctp-blue); text-decoration: none;">← back to projects</a>
      </div>
    </article>
  </LineGutter>
</EditorLayout>
