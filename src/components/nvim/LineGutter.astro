---
/**
 * LineGutter.astro — wraps page content with relative line numbers
 *
 * Gives the "you're reading a buffer" effect. Usage:
 *   <LineGutter>
 *     <div class="prose">…content…</div>
 *   </LineGutter>
 */
interface Props {
  /** Number of visible lines to pre-render (default 60) */
  lines?: number;
  /** 1-based current line to highlight as cursor line */
  cursorLine?: number;
}

const { lines = 60, cursorLine = 1 } = Astro.props;
---

<div class="editor-gutter" data-gutter>
  <!-- Gutter column (line numbers rendered via JS so they match actual content) -->
  <div class="gutter-col" id="gutter-numbers" aria-hidden="true">
    {Array.from({ length: lines }, (_, i) => {
      const n = i + 1;
      const rel = Math.abs(n - cursorLine);
      return (
        <div
          class:list={['ln', { 'current-ln': n === cursorLine, 'cursorline': n === cursorLine }]}
          data-ln={n}
          style={n === cursorLine ? 'color: var(--ctp-overlay2)' : ''}
        >
          {n === cursorLine ? n : (rel === 0 ? n : rel)}
        </div>
      );
    })}
  </div>

  <!-- Content column -->
  <div class="content-col">
    <slot />
  </div>
</div>

<script>
  // Update line numbers dynamically based on actual rendered content height
  (function() {
    const gutter = document.getElementById('gutter-numbers');
    const content = document.querySelector('[data-gutter] .content-col');
    if (!gutter || !content) return;

    let updating = false;

    function update() {
      if (updating) return;
      updating = true;

      const firstLn = gutter.firstElementChild;
      const lineH = firstLn ? firstLn.getBoundingClientRect().height : 23;
      if (lineH <= 0) { updating = false; return; }

      const target = Math.ceil(content.scrollHeight / lineH);
      const current = gutter.children.length;

      if (target > current) {
        for (let i = current; i < target; i++) {
          const div = document.createElement('div');
          div.className = 'ln';
          div.textContent = String(i + 1);
          gutter.appendChild(div);
        }
      } else if (target < current) {
        while (gutter.children.length > target) {
          gutter.removeChild(gutter.lastElementChild as Element);
        }
      }

      updating = false;
    }

    update();
    new ResizeObserver(update).observe(content);
  })();
</script>
